from flask import Flask, request, jsonify
from flask_cors import CORS
from logic import calculate_financials
from groq import Groq

app = Flask(__name__)
CORS(app)

# 🔑 Add your Groq API key here
client = Groq(api_key="your api key")


#financial analysis route
@app.route('/analyze', methods=['POST'])
def analyze():
    data = request.json
    result = calculate_financials(data)
    return jsonify(result)


# chatbot route
@app.route('/chat', methods=['POST'])
def chat():
    data = request.json
    message = data.get("message")

   
    income = data.get("income")
    expenses = data.get("expenses")
    savings = data.get("savings")

    context = f"""
    User financial details:
    Income: {income}
    Expenses: {expenses}
    Savings: {savings}
    """

    try:
        response = client.chat.completions.create(
            model="llama-3.1-8b-instant",
            messages=[
                {
                    "role": "system",
                    "content": "You are a certified financial advisor. Give short, practical, personalized advice."
                },
                {
                    "role": "user",
                    "content": context + "\nUser question: " + message
                }
            ]
        )

        reply = response.choices[0].message.content

    except Exception as e:
        reply = "AI service unavailable."

    return jsonify({"reply": reply})

       


if __name__ == "__main__":
    app.run(debug=True)
